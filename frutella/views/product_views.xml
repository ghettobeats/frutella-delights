<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Heredar lista de productos -->
    <record id="view_ms_product_tree" model="ir.ui.view">
        <field name="name">ms.product.template.tree</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="min_stock"/>
                <field name="low_stock" string="Stock Bajo" optional="show"/>
            </field>
        </field>
    </record>

    <!-- Heredar formulario de productos -->
    <record id="view_ms_product_form" model="ir.ui.view">
        <field name="name">ms.product.template.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="uom_po_id" position="after">
                <group name="ms_uom_simple" invisible="has_uom_group" colspan="2">
                    <field name="has_uom_group" invisible="1"/>
                    <field name="uom_id_simple"/>
                    <field name="uom_po_id_simple"/>
                </group>
            </field>
            <xpath expr="//notebook" position="inside">
                <page string="Control de Stock" name="stock_control">
                    <group>
                        <field name="min_stock"/>
                        <field name="low_stock" widget="boolean_toggle" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Acción para productos con stock bajo -->
    <record id="action_ms_low_stock" model="ir.actions.act_window">
        <field name="name">Productos con Stock Bajo</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('low_stock', '=', True)]</field>
        <field name="context">{'search_default_low_stock': 1}</field>
    </record>

    <!-- Acción general de productos -->
    <record id="action_ms_product" model="ir.actions.act_window">
        <field name="name">Productos</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
<record id="action_ms_stock_moves" model="ir.actions.act_window">
    <field name="name">Movimientos de Stock</field>
    <field name="res_model">stock.move</field>
    <field name="view_mode">tree,form</field>
</record>
</odoo>