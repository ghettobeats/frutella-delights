<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_ms_sale_document">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2 class="text-center">Reporte de Venta</h2>
                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Referencia: </strong>
                                <span t-field="doc.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Fecha: </strong>
                                <span t-field="doc.date"/>
                            </div>
                            <div class="col-6 mt-2">
                                <strong>Estado: </strong>
                                <span t-field="doc.state"/>
                            </div>
                        </div>

                        <table class="table table-bordered mt-4">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-right">Cantidad</th>
                                    <th class="text-right">Precio Venta</th>
                                    <th class="text-right">Costo Unitario</th>
                                    <th class="text-right">Subtotal</th>
                                    <th class="text-right">Costo Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.sale_line_ids" t-as="line">
                                    <tr>
                                        <td><span t-field="line.product_id.name"/></td>
                                        <td class="text-right"><span t-field="line.quantity"/></td>
                                        <td class="text-right">
                                            <span t-field="line.price" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.cost_unit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.subtotal" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row">
                            <div class="col-6 offset-6">
                                <table class="table table-bordered">
                                    <tr>
                                        <td><strong>Total Venta</strong></td>
                                        <td class="text-right">
                                            <span t-field="doc.total" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Costo Total</strong></td>
                                        <td class="text-right">
                                            <span t-field="doc.total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr t-att-class="'bg-success text-white' if doc.profit >= 0 else 'bg-danger text-white'">
                                        <td><strong>Ganancia / Pérdida</strong></td>
                                        <td class="text-right">
                                            <strong><span t-field="doc.profit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_ms_sale" model="ir.actions.report">
        <field name="name">Reporte de Venta</field>
        <field name="model">ms.sale</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">frutella.report_ms_sale_document</field>
        <field name="report_file">frutella.report_ms_sale_document</field>
        <field name="binding_model_id" ref="model_ms_sale"/>
        <field name="binding_type">report</field>
    </record>

</odoo>